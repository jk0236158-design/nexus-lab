PORT=3000

# At least one of API_KEYS / JWT_SECRET must be configured.
API_KEYS=key1,key2
JWT_SECRET=change-me

# Post-auth rate limit: keyed by authenticated user/key.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Pre-auth rate limit: keyed by client IP. Applied BEFORE authMiddleware so
# invalid-credential and missing-credential attempts consume this bucket.
# Keep this tighter than RATE_LIMIT_MAX to slow brute-force attempts.
PREAUTH_RATE_LIMIT_MAX=30
PREAUTH_RATE_LIMIT_WINDOW_MS=60000

# Comma-separated list of allowed browser origins for CORS. Leave empty to
# disable CORS entirely (recommended when the server is accessed only from
# non-browser MCP clients). Setting `*` is NOT supported — this server uses
# Authorization / x-api-key headers, and a wildcard would let any origin's
# browser replay those credentials.
CORS_ORIGINS=

# Maximum JSON body size accepted by the HTTP layer. Default 1mb. Raise only
# if your MCP payloads legitimately need it; unbounded bodies let an
# unauthenticated peer pin process memory before auth even runs.
BODY_LIMIT=1mb
