{
  "name": "create-mcp-server",
  "version": "0.1.0",
  "description": "Scaffold a new MCP server project with TypeScript, testing, and secure defaults",
  "type": "module",
  "bin": {
    "create-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.js",
    "dev": "tsc --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "scaffold",
    "template",
    "cli",
    "create"
  ],
  "author": "Nexus Lab",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.0.0",
    "prompts": "^2.4.2",
    "chalk": "^5.4.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
